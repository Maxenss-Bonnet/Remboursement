{
    "json.schemas": [],
    
    // Configuration Markdown PDF (yzane) - Optimisé pour Word/PDF
    "markdown-pdf.type": ["pdf", "html"],
    "markdown-pdf.outputDirectory": "output",
    "markdown-pdf.styles": [
        "style.css"
    ],
    "markdown-pdf.includeDefaultStyles": false,
    "markdown-pdf.highlight": true,
    "markdown-pdf.highlightStyle": "github.css",
    "markdown-pdf.breaks": true,
    "markdown-pdf.emoji": true,
    
    // Optimisations PDF pour Word
    "markdown-pdf.format": "A4",
    "markdown-pdf.orientation": "portrait",
    "markdown-pdf.margin.top": "20mm",
    "markdown-pdf.margin.bottom": "22mm",
    "markdown-pdf.margin.right": "20mm",
    "markdown-pdf.margin.left": "20mm",
    "markdown-pdf.printBackground": true,
    "markdown-pdf.scale": 1,
    
    // Templates pour headers/footers professionnels
    "markdown-pdf.displayHeaderFooter": true,
    "markdown-pdf.headerTemplate": "<div style=\"font-size: 9px; margin-left: 1cm; color: #718096;\"><span class='title'></span></div><div style=\"font-size: 9px; margin-left: auto; margin-right: 1cm; color: #718096;\">%%ISO-DATE%%</div>",
    "markdown-pdf.footerTemplate": "<div style=\"font-size: 9px; margin: 0 auto; color: #718096;\">Rapport de Stage – Maxence Bonnet  •  Page <span class='pageNumber'></span> / <span class='totalPages'></span></div>",
    
    // Améliorations qualité et compatibilité
    "markdown-pdf.quality": 100,
    "markdown-pdf.omitBackground": false
}